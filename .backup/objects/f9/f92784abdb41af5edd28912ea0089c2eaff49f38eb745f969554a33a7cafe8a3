    /**
     * 从assets读取MD文档，转HTML后用WebView显示在Dialog中
     */
    private fun showMdDoc(title: String, assetFileName: String) {
        lifecycleScope.launch {
            val htmlContent = withContext(Dispatchers.IO) {
                try {
                    val mdText = assets.open(assetFileName).bufferedReader().use { it.readText() }
                    mdToHtml(mdText)
                } catch (e: Exception) {
                    "<html><body><h2>加载失败</h2><p>${e.message}</p></body></html>"
                }
            }

            val webView = android.webkit.WebView(this@MainActivity).apply {
                settings.javaScriptEnabled = false
                settings.allowFileAccess = false
                settings.loadWithOverviewMode = true
                settings.useWideViewPort = true
                setBackgroundColor(android.graphics.Color.parseColor("#FFEEF1F5"))
                loadDataWithBaseURL(null, htmlContent, "text/html", "UTF-8", null)
            }

            MaterialAlertDialogBuilder(this@MainActivity)
                .setTitle(title)
                .setView(webView)
                .setPositiveButton("关闭", null)
                .show()
        }
    }

    /**
     * 将简单的 Markdown 文本转换为 HTML
     */
    private fun mdToHtml(md: String): String {
        val sb = StringBuilder()
        sb.append("""
            <!DOCTYPE html>
            <html>
            <head>
                <meta charset="UTF-8">
                <meta name="viewport" content="width=device-width, initial-scale=1.0">
                <style>
                    body {
                        font-family: -apple-system, system-ui, sans-serif;
                        font-size: 14px;
                        line-height: 1.6;
                        color: #1C1B1F;
                        padding: 8px 12px;
                        background: #F8F9FF;
                    }
                    h1 { font-size: 18px; color: #1565C0; margin: 12px 0 8px; padding-bottom: 4px; border-bottom: 1px solid #DEDEDE; }
                    h2 { font-size: 16px; color: #1565C0; margin: 10px 0 6px; }
                    h3 { font-size: 14px; color: #1565C0; margin: 8px 0 4px; }
                    p { margin: 6px 0; }
                    code {
                        background: #E8F0FE;
                        color: #C62828;
                        padding: 1px 5px;
                        border-radius: 3px;
                        font-family: monospace;
                        font-size: 12px;
                    }
                    pre {
                        background: #F5F7FA;
                        border: 1px solid #DEDEDE;
                        border-radius: 6px;
                        padding: 8px 12px;
                        overflow-x: auto;
                        font-size: 12px;
                        line-height: 1.5;
                    }
                    pre code {
                        background: none;
                        color: #333333;
                        padding: 0;
                    }
                    table {
                        width: 100%;
                        border-collapse: collapse;
                        margin: 8px 0;
                        font-size: 12px;
                    }
                    th {
                        background: #1565C0;
                        color: white;
                        padding: 6px 8px;
                        text-align: left;
                    }
                    td {
                        border: 1px solid #DEDEDE;
                        padding: 5px 8px;
                    }
                    tr:nth-child(even) { background: #F5F7FA; }
                    blockquote {
                        border-left: 3px solid #1565C0;
                        margin: 8px 0;
                        padding: 4px 12px;
                        background: #E8F0FE;
                        border-radius: 0 4px 4px 0;
                    }
                    ul, ol { margin: 4px 0; padding-left: 20px; }
                    li { margin: 2px 0; }
                </style>
            </head>
            <body>
        """.trimIndent())

        // 简易 Markdown → HTML 转换（支持表格、代码块、标题、列表等）
        val lines = md.split("\n")
        var inCodeBlock = false
        var inTable = false
        var tableSb = StringBuilder()
        var isFirstTableRow = true

        for (line in lines) {
            when {
                // 代码块开始/结束
                line.trimStart().startsWith("```") -> {
                    if (inCodeBlock) {
                        sb.append("</code></pre>\n")
                        inCodeBlock = false
                    } else {
                        sb.append("<pre><code>")
                        inCodeBlock = true
                    }
                    continue
                }
                inCodeBlock -> {
                    sb.append(escapeHtml(line)).append("\n")
                    continue
                }
                // 表格行
                line.trimStart().startsWith("|") && line.trimEnd().endsWith("|") -> {
                    val cells = line.split("|").filter { it.isNotBlank() }
                    if (cells.isEmpty() || cells.all { it.trim().all { c -> c == '-' || c == ':' } }) {
                        // 分隔行，跳过
                        continue
                    }
                    if (!inTable) {
                        inTable = true
                        isFirstTableRow = true
                        tableSb = StringBuilder("<table>")
                    }
                    if (isFirstTableRow) {
                        tableSb.append("<thead><tr>")
                        for (cell in cells) {
                            tableSb.append("<th>${escapeHtml(cell.trim())}</th>")
                        }
                        tableSb.append("</tr></thead><tbody>")
                        isFirstTableRow = false
                    } else {
                        tableSb.append("<tr>")
                        for (cell in cells) {
                            tableSb.append("<td>${escapeHtml(cell.trim())}</td>")
                        }
                        tableSb.append("</tr>")
                    }
                    continue
                }
                line.isBlank() && inTable -> {
                    inTable = false
                    tableSb.append("</tbody></table>")
                    sb.append(tableSb.toString())
                    tableSb = StringBuilder()
                    continue
                }
                inTable -> {
                    // 非空行且不在表格模式
                    continue
                }
            }

            // 处理标题
            when {
                line.startsWith("### ") -> sb.append("<h3>${escapeHtml(line.removePrefix("### "))}</h3>\n")
                line.startsWith("## ") -> sb.append("<h2>${escapeHtml(line.removePrefix("## "))}</h2>\n")
                line.startsWith("# ") -> sb.append("<h1>${escapeHtml(line.removePrefix("# "))}</h1>\n")
                line.startsWith("> ") -> sb.append("<blockquote>${escapeHtml(line.removePrefix("> "))}</blockquote>\n")
                line.startsWith("- ") || line.startsWith("* ") -> sb.append("<li>${escapeHtml(line.removePrefix("- ").removePrefix("* "))}</li>\n")
                line.matches(Regex("^\\d+\\.\\s.*")) -> sb.append("<li>${escapeHtml(line.replaceFirst(Regex("^\\d+\\.\\s"), ""))}</li>\n")
                line.isBlank() -> sb.append("<br/>\n")
                else -> {
                    // 内联 code 标记
                    var processed = escapeHtml(line)
                    // 处理 `code`
                    processed = processed.replace(Regex("`([^`]+)`")) { match ->
                        "<code>${match.groupValues[1]}</code>"
                    }
                    // 处理 **bold**
                    processed = processed.replace(Regex("\\*\\*(.+?)\\*\\*")) { match ->
                        "<strong>${match.groupValues[1]}</strong>"
                    }
                    sb.append("<p>$processed</p>\n")
                }
            }
        }

        // 如果表格未闭合
        if (inTable) {
            tableSb.append("</tbody></table>")
            sb.append(tableSb.toString())
        }

        sb.append("</body></html>")
        return sb.toString()
    }

    private fun escapeHtml(text: String): String {
        return text
            .replace("&", "&" + "amp;")
            .replace("<", "&" + "lt;")
            .replace(">", "&" + "gt;")
            .replace("\"", "&" + "quot;")
    }
    override fun onDestroy() {
        super.onDestroy()
        _binding = null
    }
}
