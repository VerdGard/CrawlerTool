/**
 * 语法类型枚举：标记选择器表达式属于哪种语法
 */
private enum class SyntaxType {
    XPATH,     // 明显是 XPath 语法（以 / 或 // 开头或包含 @ ）
    JSOUP,     // 明显是 Jsoup/CSS 选择器语法
    AMBIGUOUS // 无法明确判断
}

