    /**
     * 检测表达式属于哪种语法类型
     * 通过特征符号判断：XPath 以 / 或 // 开头，或包含 /@ ；Jsoup 则为 tag / . / # 开头
     */
    private fun detectSyntax(expr: String): SyntaxType {
        val trimmed = expr.trim()
        if (trimmed.isBlank()) return SyntaxType.AMBIGUOUS

        // 1. 显式 XPath 特征
        //    - 以 / 或 // 开头（绝对路径或相对路径）
        //    - 包含  [@ 属性选择（如 div[@class='x']）
        //    - 包含 /@ 属性轴（如 //a/@href）
        //    - 包含 .. 或 . （父/当前节点）
        //    - 包含 [position() 或 [last() 或 [not(
        //    - 包含 | （联合运算符）
        //    - 包含 *[ 或 /* （通配符路径）
        if (trimmed.startsWith("/") ||
            trimmed.contains("[@") ||
            trimmed.contains("/@") ||
            trimmed.contains("[position()") ||
            trimmed.contains("[last()") ||
            trimmed.contains("[not(") ||
            trimmed.startsWith("*[") ||
            trimmed.startsWith("/*") ||
            trimmed.startsWith("//*") ||
            trimmed.startsWith("(")
        ) {
            return SyntaxType.XPATH
        }

        // 2. 显式 Jsoup/CSS 特征
        //    - 以 . 开头（class选择器）
        //    - 以 # 开头（id选择器）
        //    - 包含 :contains 等伪类（非XPath标准）
        //    - 标签选择器常见形式：字母开头但不含 / 和 @
        //    - 包含 : 伪类选择器（如 :has、:contains、:not、:nth-）
        //    - 使用 > 直接子选择器
        if (trimmed.startsWith(".") ||
            trimmed.startsWith("#") ||
            trimmed.startsWith(":") ||
            trimmed.contains(":contains(") ||
            trimmed.contains(":has(") ||
            trimmed.contains(":nth-") ||
            trimmed.contains(":gt(") ||
            trimmed.contains(":lt(") ||
            trimmed.contains(":first") ||
            trimmed.contains(":last") ||
            trimmed.contains("::")
        ) {
            return SyntaxType.JSOUP
        }

        // 3. 判断关键符号：是否包含 / 或 @ —— 这些在 Jsoup 中不常见
        if (trimmed.contains("/") || trimmed.contains("@")) {
            return SyntaxType.XPATH
        }

        // 4. 包含 > 或 ~ 或 + —— CSS 组合器，Jsoup 特有
        if (trimmed.contains(">") || trimmed.contains("~") || trimmed.contains("+")) {
            return SyntaxType.JSOUP
        }

        // 5. 多个标签选择器用空格分隔且不含 XPath 特征 -> Jsoup
        //    简单 tag 选择如 a, div, span, .class, #id
        if (trimmed.matches(Regex("^[a-zA-Z_][\\w-]*$")) ||
            trimmed.matches(Regex("^[a-zA-Z_][\\w-]*\\[[^/]+]$"))  // 如 a[href] 不带 /
        ) {
            return SyntaxType.JSOUP
        }

        // 6. 包含 [ 但引号内没有 / 或 @ 的复杂属性选择
        if (trimmed.matches(Regex("^[\\w.#:*-]+(\\[[^/]+])*([,>+~\\s][\\w.#:*-]+(\\[[^/]+])*)*$"))) {
            return SyntaxType.JSOUP
        }

        return SyntaxType.AMBIGUOUS
    }

    /**
     * 智能转换：将表达式从一种语法转换为另一种
     * 注意：这是启发式转换，对于复杂表达式可能不完美，但能处理常见情况
     */
    private fun convertExpression(expr: String, from: SyntaxType, to: SyntaxType): String {
        val trimmed = expr.trim()
        
        return when {
            // XPath → Jsoup 转换
            from == SyntaxType.XPATH && to == SyntaxType.JSOUP -> {
                var result = trimmed
                // 去掉开头的 //
                result = result.replaceFirst("^//".toRegex(), "")
                // 去掉开头的单个 /
                result = result.replaceFirst("^/".toRegex(), "")
                // //a[@href] → a[href]  将 [@attr] → [attr]
                result = result.replace(Regex("""\[@([^\]]+)]""")) { match ->
                    "[${match.groupValues[1]}]"
                }
                // /@href → href（属性轴转为单独获取属性）
                result = result.replace(Regex("/@(\\w+)$"), ".attr('$1')")
                // [position()=n] → :nth-child(n)
                result = result.replace(Regex("""\[position\(\)\s*=\s*(\d+)]""")) { match ->
                    ":nth-child(${match.groupValues[1]})"
                }
                // [last()] → :last
                result = result.replace("[last()]", ":last")
                // 去掉 contains(text(), 'xxx') → :contains(xxx)
                result = result.replace(Regex("""contains\(text\(\),\s*'([^']*)'\)""")) { match ->
                    ":contains(${match.groupValues[1]})"
                }
                // 去掉 contains(., 'xxx') → :contains(xxx)
                result = result.replace(Regex("""contains\(\.\s*,\s*'([^']*)'\)""")) { match ->
                    ":contains(${match.groupValues[1]})"
                }
                // //div | //a → div, a
                result = result.replace(Regex("""//(\w+)\s*\|\s*//""")) { match ->
                    "${match.groupValues[1]}, "
                }
                result = result.replaceFirst(Regex("^\\s*\\|\\s*//"), "")
                // 去掉剩余的 | //
                result = result.replace(Regex("\\|\\s*//"), ", ")
                // // → 空格（子孙选择器变空格）
                result = result.replace("//", " ")
                // / → > （子选择器）
                result = result.replace("/", " > ")
                // 清理多余空格
                result = result.trim().replace(Regex("\\s+"), " ")
                result
            }
            // Jsoup → XPath 转换
            from == SyntaxType.JSOUP && to == SyntaxType.XPATH -> {
                var result = trimmed
                // :contains(xxx) → [contains(text(), 'xxx')]
                result = result.replace(Regex(""":contains\(([^)]+)\)""")) { match ->
                    val text = match.groupValues[1]
                    "[contains(text(), '$text')]"
                }
                // :has(selector) → [.//selector] 简化处理
                result = result.replace(Regex(""":has\(([^)]+)\)""")) { match ->
                    "[.//${match.groupValues[1]}]"
                }
                // :nth-child(n) → [position()=n]
                result = result.replace(Regex(""":nth-child\((\d+)\)""")) { match ->
                    "[position()=${match.groupValues[1]}]"
                }
                // :first → [1]
                result = result.replace(":first", "[1]")
                // :last → [last()]
                result = result.replace(":last", "[last()]")
                // :not(selector) → [not(selector)]
                result = result.replace(Regex(""":not\(([^)]+)\)""")) { match ->
                    val sel = match.groupValues[1]
                    if (sel.startsWith(".") || sel.startsWith("#")) {
                        "[not(@${if (sel.startsWith(".")) "class='${sel.drop(1)}'" else "id='${sel.drop(1)}'"})]"
                    } else {
                        "[not(self::$sel)]"
                    }
                }
                // 属性选择器 [attr=value] → [@attr='value']
                // 需要处理引号：a[href="xxx"] → a[@href='xxx']
                result = result.replace(Regex("""\[([^=]+)=["']([^"']*)["']]""")) { match ->
                    "[@${match.groupValues[1]}='${match.groupValues[2]}']"
                }
                // 无值属性 [attr] → [@attr]
                result = result.replace(Regex("""\[([^@=/\]]+)]""")) { match ->
                    "[@${match.groupValues[1]}]"
                }
                // .class → [@class='class']
                result = result.replace(Regex("""(?<=^|[\s>+,])\.([\w-]+)""")) { match ->
                    "[@class='${match.groupValues[1]}']"
                }
                // #id → [@id='id']
                result = result.replace(Regex("""(?<=^|[\s>+,])#([\w-]+)""")) { match ->
                    "[@id='${match.groupValues[1]}']"
                }
                // > → /（子选择器）
                result = result.replace(">", "/")
                // 空格（后代选择器）→ //（但注意不要替换掉属性值中的空格）
                // 简单策略：在 tag 和选择器之间转换
                result = result.replace(Regex("""(?<=[\w)\]]) (?=[\w.\[]|\[)"""), "//")
                // 开头添加 // 如果以 tag 或 [ 开头
                if (result.matches(Regex("^[\\w.\\[]"))) {
                    result = "//$result"
                }
                // 清理多余空格
                result = result.trim().replace(Regex("\\s+"), " ")
                result
            }
            else -> trimmed // 不变
        }
    }

    /**
     * 检查语法是否匹配当前模式，若不匹配则弹出对话框询问是否自动转换
     * @return true 表示已处理转换（无需继续执行匹配），false 表示无需转换可正常执行
     */
    private fun checkAndSuggestConversion(): Boolean {
        val expression = binding.etExpression.text.toString().trim()
        if (expression.isBlank()) return false
        
        val detected = detectSyntax(expression)
        if (detected == SyntaxType.AMBIGUOUS) return false
        
        // 判断是否与当前模式匹配
        val isMatch = when (matchMode) {
            CrawlerEngine.MatchMode.XPath -> detected == SyntaxType.XPATH
            CrawlerEngine.MatchMode.Jsoup -> detected == SyntaxType.JSOUP
        }
        
        // 如果匹配，不需要转换
        if (isMatch) return false
        
        // 不匹配：构造对话框
        val currentModeName = when (matchMode) {
            CrawlerEngine.MatchMode.XPath -> "XPath"
            CrawlerEngine.MatchMode.Jsoup -> "Jsoup"
        }
        val detectedModeName = when (detected) {
            SyntaxType.XPATH -> "XPath"
            SyntaxType.JSOUP -> "Jsoup"
            SyntaxType.AMBIGUOUS -> ""
        }
        
        // 计算转换后的表达式
        val targetMode = when (matchMode) {
            CrawlerEngine.MatchMode.XPath -> CrawlerEngine.MatchMode.Jsoup
            CrawlerEngine.MatchMode.Jsoup -> CrawlerEngine.MatchMode.XPath
        }
        val targetSyntax = when (targetMode) {
            CrawlerEngine.MatchMode.XPath -> SyntaxType.XPATH
            CrawlerEngine.MatchMode.Jsoup -> SyntaxType.JSOUP
        }
        val convertedExpr = convertExpression(expression, detected, targetSyntax)
        
        MaterialAlertDialogBuilder(this)
            .setTitle("语法模式不匹配")
            .setMessage("当前模式为「$currentModeName」，检测到输入的是「$detectedModeName」语法。\n\n是否自动转换为「$currentModeName」格式？\n\n转换结果：\n$convertedExpr")
            .setPositiveButton("转换并匹配") { _, _ ->
                // 切换模式
                matchMode = targetMode
                val modes = arrayOf("XPath", "Jsoup")
                val modeIndex = when (targetMode) {
                    CrawlerEngine.MatchMode.XPath -> 0
                    CrawlerEngine.MatchMode.Jsoup -> 1
                }
                binding.actMode.setText(modes[modeIndex], false)
                
                // 更新输入框内容为转换后的表达式
                binding.etExpression.setText(convertedExpr)
                
                // 更新hint提示
                when (targetMode) {
                    CrawlerEngine.MatchMode.XPath -> {
                        binding.exprInputLayout.hint = "XPath表达式（如 //a/@href）"
                    }
                    CrawlerEngine.MatchMode.Jsoup -> {
                        binding.exprInputLayout.hint = "Jsoup CSS选择器（如 a[href]）"
                    }
                }
                
                // 执行匹配
                performMatch()
            }
            .setNegativeButton("取消", null)
            .setNeutralButton("仍用原模式匹配") { _, _ ->
                // 保持当前模式和表达式，正常执行匹配
                performMatch()
            }
            .setIcon(android.R.drawable.ic_menu_edit)
            .show()
        
        return true // 已处理，对话框会触发匹配
    }

    private fun performMatch() {
        val url = binding.etUrl.text.toString().trim()
        val expression = binding.etExpression.text.toString().trim()

        // 基本校验
        if (url.isBlank() || url == "https://") {
            Toast.makeText(this, "请输入有效的URL", Toast.LENGTH_SHORT).show()
            return
        }
        if (expression.isBlank()) {
            Toast.makeText(this, "请输入匹配表达式", Toast.LENGTH_SHORT).show()
            return
        }

        // 语法检测：如果输入语法与当前模式不匹配，弹出转换建议对话框
        if (checkAndSuggestConversion()) {
            // 对话框已弹出，不再继续执行匹配（按钮回调中会重新调用 performMatch）
            return
        }

        binding.btnMatch.isEnabled = false
        binding.tvStatus.text = "正在请求并匹配..."

        lifecycleScope.launch {
            val result = withContext(Dispatchers.IO) {
                CrawlerEngine.fetchAndMatch(
                    url = url,
                    expression = expression,
                    mode = matchMode
                )
            }

            binding.btnMatch.isEnabled = true

            result.fold(
                onSuccess = { items ->
                    if (items.isEmpty()) {
                        binding.tvStatus.text = "匹配完成，未找到结果"
                        adapter.submitList(emptyList())
                        Toast.makeText(this@MainActivity, "未匹配到任何结果", Toast.LENGTH_SHORT).show()
                    } else {
                        val resultItems = items.mapIndexed { index, content ->
                            ResultItem(index = index + 1, content = content)
                        }
                        adapter.submitList(resultItems)
                        binding.tvStatus.text = "匹配完成，共 ${items.size} 条结果"
                    }
                },
                onFailure = { error ->
                    binding.tvStatus.text = "匹配失败"
                    adapter.submitList(emptyList())
                    showErrorDialog("匹配失败", error.message ?: "未知错误")
                }
            )
        }
    }

    private fun copyRuleExpression() {
        val expression = binding.etExpression.text.toString().trim()
        if (expression.isEmpty()) {
            Toast.makeText(this, "规则表达式为空，无可复制的内容", Toast.LENGTH_SHORT).show()
            return
        }

        val clipboard = getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
        val clip = ClipData.newPlainText("Crawler Rule", expression)
        clipboard.setPrimaryClip(clip)
        Toast.makeText(this, "已复制规则表达式", Toast.LENGTH_SHORT).show()
    }

    private fun showErrorDialog(title: String, message: String) {
        MaterialAlertDialogBuilder(this)
            .setTitle(title)
            .setMessage(message)
            .setPositiveButton("确定", null)
            .setIcon(android.R.drawable.ic_dialog_alert)
            .show()
    }

