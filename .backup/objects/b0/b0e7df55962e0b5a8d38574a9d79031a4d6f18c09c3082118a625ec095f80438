<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background"
    tools:context="com.SoloSu.Crawler_tool.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:translationZ="6dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/md_surface"
            app:title="Crawler Tool"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/md_on_surface"
            app:menu="@menu/toolbar_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- 输入卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:cardElevation="3dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                app:contentPadding="12dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 第一行：URL + 模式选择器 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/urlInputLayout"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            app:startIconDrawable="@android:drawable/ic_menu_search"
                            app:hintEnabled="true"
                            app:boxStrokeWidth="1.5dp"
                            android:hint="输入网站URL...">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etUrl"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textUri"
                                android:singleLine="true"
                                android:text="https://" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- 匹配模式选择器：Jsoup / XPath -->
                        <RadioGroup
                            android:id="@+id/modeRadioGroup"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:checkedButton="@+id/radioJsoup">

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioJsoup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jsoup"
                                android:textSize="12sp"
                                android:paddingVertical="0dp" />

                            <com.google.android.material.radiobutton.MaterialRadioButton
                                android:id="@+id/radioXPath"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="XPath"
                                android:textSize="12sp"
                                android:paddingVertical="0dp" />

                        </RadioGroup>

                    </LinearLayout>

                    <!-- 表达式输入 -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/exprInputLayout"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        app:startIconDrawable="@android:drawable/ic_menu_edit"
                        app:hintEnabled="true"
                        app:boxStrokeWidth="1.5dp"
                        android:hint="Jsoup CSS选择器 或 XPath表达式">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etExpression"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:singleLine="true"
                            android:text="a[href]" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- 快捷标签（Flow 换行，不滑动） -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="快捷属性标签:"
                        android:textSize="12sp"
                        android:textColor="@color/md_on_surface_variant"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/quickAttrChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        app:singleLine="false"
                        app:chipSpacing="4dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTitle"
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@title"
                            android:textSize="11sp"
                            android:textColor="@color/chip_text_color"
                            app:chipBackgroundColor="@color/chip_background"
                            app:chipMinTouchTargetSize="28dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipHref"
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@href"
                            android:textSize="11sp"
                            android:textColor="@color/chip_text_color"
                            app:chipBackgroundColor="@color/chip_background"
                            app:chipMinTouchTargetSize="28dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipDataOriginal"
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@data-original"
                            android:textSize="11sp"
                            android:textColor="@color/chip_text_color"
                            app:chipBackgroundColor="@color/chip_background"
                            app:chipMinTouchTargetSize="28dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipDataSrc"
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@data-src"
                            android:textSize="11sp"
                            android:textColor="@color/chip_text_color"
                            app:chipBackgroundColor="@color/chip_background"
                            app:chipMinTouchTargetSize="28dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipText"
                            style="@style/Widget.Material3.Chip.Suggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="text()"
                            android:textSize="11sp"
                            android:textColor="@color/chip_text_color"
                            app:chipBackgroundColor="@color/chip_background"
                            app:chipMinTouchTargetSize="28dp" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- 操作按钮 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMatch"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:text="匹配"
                            android:textSize="14sp"
                            app:cornerRadius="22dp"
                            app:backgroundTint="@color/md_primary"
                            android:textColor="@color/md_on_primary"
                            app:icon="@android:drawable/ic_menu_compass"
                            app:iconGravity="textStart"
                            app:iconSize="18dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClear"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="清空"
                            android:textSize="14sp"
                            app:cornerRadius="22dp"
                            app:strokeColor="@color/md_primary"
                            app:strokeWidth="1dp"
                            android:textColor="@color/md_primary"
                            app:icon="@android:drawable/ic_menu_close_clear_cancel"
                            app:iconGravity="textStart"
                            app:iconSize="18dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 结果卡片（自适应高度） -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/resultCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                app:cardElevation="3dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="0dp"
                app:contentPadding="10dp"
                app:cardBackgroundColor="@color/card_background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="匹配结果"
                            android:textSize="14sp"
                            android:textColor="@color/md_on_surface"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCopyAll"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="复制全部"
                            android:textSize="11sp"
                            android:minHeight="0dp"
                            android:paddingVertical="4dp"
                            android:paddingHorizontal="12dp"
                            app:cornerRadius="16dp"
                            app:backgroundTint="@color/md_primary_container"
                            android:textColor="@color/md_on_primary_container" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="0.5dp"
                        android:background="@color/divider_color"
                        android:layout_marginBottom="6dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:clipToPadding="false"
                        android:padding="2dp"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 底部状态栏 -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="就绪"
                android:textSize="11sp"
                android:textColor="@color/md_on_surface_variant"
                android:gravity="center"
                android:paddingVertical="4dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
