package com.SoloSu.Crawler_tool

import android.annotation.SuppressLint
import android.content.ClipData
import android.content.ClipboardManager
import android.content.Context
import android.content.Intent
import android.graphics.Typeface
import android.os.Bundle
import android.text.SpannableStringBuilder
import android.text.style.ForegroundColorSpan
import android.view.Gravity
import android.view.MotionEvent
import android.view.ScaleGestureDetector
import android.view.View
import android.widget.HorizontalScrollView
import android.widget.LinearLayout
import android.widget.TextView
import android.widget.Toast
import androidx.appcompat.app.AppCompatActivity
import androidx.core.content.ContextCompat
import com.google.android.material.button.MaterialButton
import org.jsoup.Jsoup
import org.jsoup.nodes.Element
import java.util.regex.Pattern

/**
 * 全屏 HTML 树状图 Activity
 * 水平滚动、双指缩放、长按复制 CSS 选择器
 */
class HtmlTreeActivity : AppCompatActivity() {

    companion object {
        // 用于"缩小"回对话框时传递数据
        var pendingHtmlContent: String? = null
        var pendingOnSelectPath: ((String) -> Unit)? = null
    }

    @SuppressLint("ClickableViewAccessibility")
    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)

        val htmlContent = intent.getStringExtra("htmlContent") ?: run {
            Toast.makeText(this, "缺少 HTML 内容", Toast.LENGTH_SHORT).show()
            finish()
            return
        }

        // 保存到静态变量，以便"缩小"按钮重新弹出对话框时使用
        pendingHtmlContent = htmlContent

        try {
            val doc = Jsoup.parse(htmlContent)
            val rootElement = doc.body()

            if (rootElement.childrenSize() == 0) {
                Toast.makeText(this, "未能解析出有效结构", Toast.LENGTH_SHORT).show()
                finish()
                return
            }

            // 缩放状态
            var currentScale = 1.0f
            val minScale = 0.6f
            val maxScale = 2.5f

            // 构建内容视图 —— 使用 HorizontalScrollView 实现左右滑动
            val horizontalScrollView = HorizontalScrollView(this).apply {
                setPadding(20, 12, 20, 12)
                isHorizontalScrollBarEnabled = true
            }

            val treeContainer = LinearLayout(this).apply {
                orientation = LinearLayout.VERTICAL
            }

            // 递归构建树节点
            fun buildTree(
                parent: LinearLayout,
                element: Element,
                depth: Int,
                isLast: Boolean,
                parentSelector: String,
                parentLines: List<Boolean>
            ) {
                val tagName = element.tagName()
                val classStr = if (element.hasAttr("class")) element.className() else ""
                val idStr = if (element.id().isNotEmpty()) "#${element.id()}" else ""

                val currentSelector = buildSelector(element, parentSelector)

                val tagContent = StringBuilder()
                for (i in 0 until depth) {
                    val isParentContinue = if (i < parentLines.size) parentLines[i] else false
                    tagContent.append(if (isParentContinue) " │  " else "    ")
                }
                tagContent.append(if (depth == 0) " ● " else if (isLast) " └─ " else " ├─ ")
                tagContent.append("<")
                tagContent.append(tagName)
                if (idStr.isNotEmpty()) tagContent.append(idStr)
                if (classStr.isNotEmpty()) tagContent.append(".$classStr")
                var addedAttr = 0
                for (attr in listOf("href", "src", "title", "alt", "data-src", "data-original")) {
                    if (element.hasAttr(attr)) {
                        val v = element.attr(attr)
                        if (v.length <= 25) {
                            tagContent.append(" $attr=\"$v\"")
                        } else {
                            tagContent.append(" $attr=\"${v.take(22)}...\"")
                        }
                        addedAttr++
                        if (addedAttr >= 2) break
                    }
                }
                val ownText = element.ownText().trim().take(20)
                if (ownText.isNotEmpty()) {
                    tagContent.append(" «$ownText»")
                }
                tagContent.append(">")

                val highlightedTag = highlightTagHtml(this@HtmlTreeActivity, tagContent.toString())
                val currentLines = parentLines + !isLast

                val nodeRow = TextView(this@HtmlTreeActivity).apply {
                    text = highlightedTag
                    textSize = 12f * currentScale
                    setPadding(4, 5, 4, 5)
                    typeface = Typeface.MONOSPACE

                    // 点击节点：不做任何操作
                    setOnClickListener {
                        // 点击不复制
                    }

                    // 长按：统一复制 CSS 选择器
                    setOnLongClickListener {
                        val clipboard = getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
                        val clip = ClipData.newPlainText("CSS Selector", currentSelector)
                        clipboard.setPrimaryClip(clip)
                        Toast.makeText(this@HtmlTreeActivity, "已复制: $currentSelector", Toast.LENGTH_SHORT).show()
                        true
                    }
                }
                parent.addView(nodeRow)

                val children = element.children()
                for (i in children.indices) {
                    val child = children[i]
                    val isLastChild = i == children.size - 1
                    buildTree(parent, child, depth + 1, isLastChild, currentSelector, currentLines)
                }
            }

            for (child in rootElement.children()) {
                buildTree(treeContainer, child, 0, true, "", emptyList())
            }

            // 缩放容器
            val zoomContainer = object : LinearLayout(this) {
                private val scaleDetector = ScaleGestureDetector(this@HtmlTreeActivity, object : ScaleGestureDetector.SimpleOnScaleGestureListener() {
                    override fun onScale(detector: ScaleGestureDetector): Boolean {
                        currentScale *= detector.scaleFactor
                        currentScale = currentScale.coerceIn(minScale, maxScale)
                        for (i in 0 until treeContainer.childCount) {
                            val v = treeContainer.getChildAt(i)
                            if (v is TextView) {
                                v.textSize = 12f * currentScale
                            }
                        }
                        return true
                    }
                })

                override fun onTouchEvent(event: MotionEvent): Boolean {
                    scaleDetector.onTouchEvent(event)
                    return super.onTouchEvent(event)
                }

                override fun onInterceptTouchEvent(ev: MotionEvent): Boolean {
                    scaleDetector.onTouchEvent(ev)
                    return super.onInterceptTouchEvent(ev)
                }
            }.apply {
                orientation = LinearLayout.VERTICAL
                addView(treeContainer)
            }

            horizontalScrollView.addView(zoomContainer)

            // 标题栏：左侧标题 + 右侧"缩小"按钮
            val titleBar = LinearLayout(this).apply {
                orientation = LinearLayout.HORIZONTAL
                gravity = Gravity.CENTER_VERTICAL
                setPadding(24, 16, 16, 8)
            }
            val titleText = TextView(this).apply {
                text = "HTML 树状图"
                textSize = 18f
                setTextColor(ContextCompat.getColor(this@HtmlTreeActivity, android.R.color.primary_text_light))
                layoutParams = LinearLayout.LayoutParams(0, LinearLayout.LayoutParams.WRAP_CONTENT, 1f)
            }
            titleBar.addView(titleText)

            val shrinkBtn = MaterialButton(this).apply {
                text = "缩小"
                setPadding(12, 4, 12, 4)
                textSize = 14f
            }
            titleBar.addView(shrinkBtn)

            // 缩小按钮：关闭 Activity 并重新弹出对话框
            shrinkBtn.setOnClickListener {
                finish()
            }

            // 总布局
            val rootLayout = LinearLayout(this).apply {
                orientation = LinearLayout.VERTICAL
                addView(titleBar)
                addView(horizontalScrollView)
            }

            setContentView(rootLayout)

        } catch (e: Exception) {
            Toast.makeText(this, "解析失败: ${e.message}", Toast.LENGTH_LONG).show()
            finish()
        }
    }

    override fun finish() {
        super.finish()
        // 关闭 Activity 后重新弹出对话框
        val html = pendingHtmlContent ?: return
        val callback = pendingOnSelectPath ?: return
        ResultAdapter.showHtmlTreeDialog(this, html, callback)
    }

    /**
     * 为 HTML 标签字符串生成语法高亮的 SpannableString
     */
    private fun highlightTagHtml(context: Context, tagHtml: String): SpannableStringBuilder {
        val sb = SpannableStringBuilder()
        val tagColor = ContextCompat.getColor(context, R.color.html_tag_color)
        val attrColor = ContextCompat.getColor(context, R.color.html_attr_color)
        val valueColor = ContextCompat.getColor(context, R.color.html_value_color)
        val textColor = ContextCompat.getColor(context, R.color.html_text_color)

        val pattern = Pattern.compile(
            "(</?)" +
            "|(/?>)" +
            "|([a-zA-Z][\\w-]*)" +
            "|(=\"[^\"]*\")" +
            "|(='[^']*')" +
            "|(=)"
        )
        val matcher = pattern.matcher(tagHtml)
        var lastEnd = 0
        var afterEquals = false

        while (matcher.find()) {
            if (matcher.start() > lastEnd) {
                val between = tagHtml.substring(lastEnd, matcher.start())
                sb.append(between)
            }

            val bracketOpen = matcher.group(1)
            val bracketClose = matcher.group(2)
            val nameToken = matcher.group(3)
            val quotedDValue = matcher.group(4)
            val quotedSValue = matcher.group(5)
            val eqSign = matcher.group(6)

            when {
                bracketOpen != null -> {
                    val s = SpannableStringBuilder(bracketOpen)
                    s.setSpan(ForegroundColorSpan(textColor), 0, s.length, 0)
                    sb.append(s)
                }
                bracketClose != null -> {
                    val s = SpannableStringBuilder(bracketClose)
                    s.setSpan(ForegroundColorSpan(textColor), 0, s.length, 0)
                    sb.append(s)
                }
                afterEquals -> {
                    if (quotedDValue != null) {
                        val s = SpannableStringBuilder(quotedDValue)
                        s.setSpan(ForegroundColorSpan(valueColor), 0, s.length, 0)
                        sb.append(s)
                    } else if (quotedSValue != null) {
                        val s = SpannableStringBuilder(quotedSValue)
                        s.setSpan(ForegroundColorSpan(valueColor), 0, s.length, 0)
                        sb.append(s)
                    } else if (nameToken != null) {
                        val s = SpannableStringBuilder(nameToken)
                        s.setSpan(ForegroundColorSpan(valueColor), 0, s.length, 0)
                        sb.append(s)
                    }
                    afterEquals = false
                }
                quotedDValue != null -> {
                    val s = SpannableStringBuilder(quotedDValue)
                    s.setSpan(ForegroundColorSpan(valueColor), 0, s.length, 0)
                    sb.append(s)
                }
                quotedSValue != null -> {
                    val s = SpannableStringBuilder(quotedSValue)
                    s.setSpan(ForegroundColorSpan(valueColor), 0, s.length, 0)
                    sb.append(s)
                }
                eqSign != null -> {
                    val s = SpannableStringBuilder(eqSign)
                    s.setSpan(ForegroundColorSpan(textColor), 0, s.length, 0)
                    sb.append(s)
                    afterEquals = true
                }
                nameToken != null -> {
                    val before = tagHtml.substring(0, matcher.start())
                    val prevChar = before.takeLastWhile { it == ' ' || it == '\t' }.let {
                        before.dropLast(it.length).lastOrNull()
                    }
                    val isAttributeName = prevChar == ' ' || prevChar == '\t' || prevChar == '\n'
                    if (isAttributeName) {
                        val s = SpannableStringBuilder(nameToken)
                        s.setSpan(ForegroundColorSpan(attrColor), 0, s.length, 0)
                        sb.append(s)
                    } else {
                        val s = SpannableStringBuilder(nameToken)
                        s.setSpan(ForegroundColorSpan(tagColor), 0, s.length, 0)
                        sb.append(s)
                    }
                }
            }
            lastEnd = matcher.end()
        }
        if (lastEnd < tagHtml.length) {
            sb.append(tagHtml.substring(lastEnd))
        }
        return sb
    }

    /**
     * 递归构建 CSS 选择器路径
     */
    private fun buildSelector(element: Element, parentSelector: String): String {
        val tag = element.tagName()
        val parent = element.parent() ?: return tag
        val siblings = parent.children().filter { it.tagName() == tag }
        val index = if (siblings.size > 1) {
            ":nth-child(${element.elementSiblingIndex() + 1})"
        } else ""
        val id = element.id()
        if (id.isNotEmpty()) {
            return if (parentSelector.isEmpty()) "#$id" else "$parentSelector > #$id"
        }
        val classes = element.classNames()
        val classSelector = if (classes.isNotEmpty()) ".${classes.joinToString(".")}" else ""
        val currentTag = "$tag$index$classSelector"
        return if (parentSelector.isEmpty()) currentTag else "$parentSelector > $currentTag"
    }
}
