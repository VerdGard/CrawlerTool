<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background"
    tools:context="com.SoloSu.Crawler_tool.MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:translationZ="6dp"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/md_surface"
            app:title="Crawler Tool"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/md_on_surface"
            app:menu="@menu/toolbar_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- 整体垂直布局：输入卡片固定顶部 + 结果列表可滚动 + 状态栏固定底部 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingTop="4dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- 输入卡片（固定顶部，不滚动） -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardElevation="3dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp"
            app:contentPadding="12dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 第一行：URL输入（全宽） -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/urlInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:hintEnabled="true"
                    app:boxStrokeWidth="1.5dp"
                    android:hint="输入网站URL...">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:singleLine="true"
                        android:text="https://" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 第二行：模式选择器（Jsoup居左 / XPath居右） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioJsoup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jsoup"
                        android:textSize="13sp"
                        android:paddingVertical="0dp"
                        android:layout_gravity="start" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <com.google.android.material.radiobutton.MaterialRadioButton
                        android:id="@+id/radioXPath"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="XPath"
                        android:textSize="13sp"
                        android:paddingVertical="0dp"
                        android:layout_gravity="end" />

                </LinearLayout>

                <!-- 表达式输入 -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/exprInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    app:hintEnabled="true"
                    app:boxStrokeWidth="1.5dp"
                    android:hint="Jsoup CSS选择器 或 XPath表达式">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etExpression"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:singleLine="true"
                        android:text="a[href]" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- 快捷属性标签（横向滚动） -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="快捷属性标签:"
                    android:textSize="12sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:layout_marginBottom="4dp" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:scrollbars="none"
                    android:overScrollMode="ifContentScrolls">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/quickAttrChipGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:chipSpacing="4dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipTitle"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@title"
                        android:textSize="11sp"
                        android:textColor="@color/chip_text_color"
                        app:chipBackgroundColor="@color/chip_background"
                        app:chipMinTouchTargetSize="28dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipHref"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@href"
                        android:textSize="11sp"
                        android:textColor="@color/chip_text_color"
                        app:chipBackgroundColor="@color/chip_background"
                        app:chipMinTouchTargetSize="28dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDataOriginal"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@data-original"
                        android:textSize="11sp"
                        android:textColor="@color/chip_text_color"
                        app:chipBackgroundColor="@color/chip_background"
                        app:chipMinTouchTargetSize="28dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipDataSrc"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@data-src"
                        android:textSize="11sp"
                        android:textColor="@color/chip_text_color"
                        app:chipBackgroundColor="@color/chip_background"
                        app:chipMinTouchTargetSize="28dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipText"
                        style="@style/Widget.Material3.Chip.Suggestion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="text()"
                        android:textSize="11sp"
                        android:textColor="@color/chip_text_color"
                        app:chipBackgroundColor="@color/chip_background"
                        app:chipMinTouchTargetSize="28dp" />

                </com.google.android.material.chip.ChipGroup>

                </HorizontalScrollView>

                <!-- 操作按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMatch"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="匹配"
                        android:textSize="14sp"
                        app:cornerRadius="22dp"
                        app:backgroundTint="@color/md_primary"
                        android:textColor="@color/md_on_primary"
                        app:icon="@android:drawable/ic_menu_compass"
                        app:iconGravity="textStart"
                        app:iconSize="18dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClear"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="清空"
                        android:textSize="14sp"
                        app:cornerRadius="22dp"
                        app:backgroundTint="@color/md_error_container"
                        app:strokeColor="@color/md_error"
                        app:strokeWidth="1.5dp"
                        android:textColor="@color/md_on_error_container"
                        app:icon="@android:drawable/ic_menu_close_clear_cancel"
                        app:iconGravity="textStart"
                        app:iconSize="18dp" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 结果卡片（占据剩余高度，内容可滚动） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/resultCard"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginBottom="4dp"
            app:cardElevation="3dp"
            app:cardCornerRadius="12dp"
            app:strokeWidth="0dp"
            app:contentPadding="10dp"
            app:cardBackgroundColor="@color/card_background">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- 标题行：固定 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="匹配结果"
                        android:textSize="14sp"
                        android:textColor="@color/md_on_surface"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="复制规则"
                        android:textSize="11sp"
                        android:minHeight="0dp"
                        android:paddingVertical="4dp"
                        android:paddingHorizontal="12dp"
                        app:cornerRadius="16dp"
                        app:backgroundTint="@color/md_primary_container"
                        android:textColor="@color/md_on_primary_container" />

                </LinearLayout>

                <!-- 分割线：固定 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="@color/divider_color"
                    android:layout_marginBottom="6dp" />

                <!-- RecyclerView：占据剩余空间，独立滚动 -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerResult"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipToPadding="false"
                    android:padding="2dp"
                    android:overScrollMode="ifContentScrolls"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 底部状态栏（固定，初始无占位文本） -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/md_on_surface_variant"
            android:gravity="center"
            android:paddingVertical="4dp" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
