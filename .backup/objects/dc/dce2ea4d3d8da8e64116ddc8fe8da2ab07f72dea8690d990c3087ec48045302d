package com.SoloSu.Crawler_tool

import android.content.ClipData
import android.content.ClipboardManager
import android.content.Context
import android.text.SpannableStringBuilder
import android.text.style.ForegroundColorSpan
import android.view.LayoutInflater
import android.view.View
import android.view.ViewGroup
import android.widget.TextView
import android.widget.Toast
import androidx.core.content.ContextCompat
import androidx.recyclerview.widget.DiffUtil
import androidx.recyclerview.widget.ListAdapter
import androidx.recyclerview.widget.RecyclerView
import com.google.android.material.card.MaterialCardView
import com.google.android.material.button.MaterialButton
import java.util.regex.Pattern

class ResultAdapter : ListAdapter<ResultItem, ResultAdapter.ViewHolder>(DiffCallback()) {

    override fun onCreateViewHolder(parent: ViewGroup, viewType: Int): ViewHolder {
        val view = LayoutInflater.from(parent.context)
            .inflate(R.layout.item_result, parent, false)
        return ViewHolder(view)
    }

    override fun onBindViewHolder(holder: ViewHolder, position: Int) {
        holder.bind(getItem(position))
    }

    inner class ViewHolder(itemView: View) : RecyclerView.ViewHolder(itemView) {
        private val tvIndex: TextView = itemView.findViewById(R.id.tvIndex)
        private val tvContent: TextView = itemView.findViewById(R.id.tvContent)
        private val tvAttrTags: TextView = itemView.findViewById(R.id.tvAttrTags)
        private val btnExpand: TextView = itemView.findViewById(R.id.btnExpand)
        private val btnCopyItem: MaterialButton = itemView.findViewById(R.id.btnCopyItem)
        private val cardItem: MaterialCardView = itemView.findViewById(R.id.cardItem)

        fun bind(item: ResultItem) {
            // 设置序号
            tvIndex.text = "${item.index}"

            // 格式化内容为带语法高亮的HTML代码风格
            tvContent.text = highlightHtmlContent(tvContent.context, item.content)

            // 提取并显示属性标签
            val attrTags = extractAttrTags(item.content)
            tvAttrTags.text = attrTags

            // 展开/折叠逻辑
            val contentLineCount = estimateLineCount(item.content)
            val needsExpand = contentLineCount > 3

            if (needsExpand) {
                btnExpand.visibility = View.VISIBLE
                if (item.expanded) {
                    tvContent.maxLines = Int.MAX_VALUE
                    btnExpand.text = "收起"
                } else {
                    tvContent.maxLines = 3
                    btnExpand.text = "展开更多内容"
                }
            } else {
                btnExpand.visibility = View.GONE
                tvContent.maxLines = Int.MAX_VALUE
            }

            // 展开按钮点击
            btnExpand.setOnClickListener {
                item.expanded = !item.expanded
                // 只更新当前 item，不刷新整个列表
                if (item.expanded) {
                    tvContent.maxLines = Int.MAX_VALUE
                    btnExpand.text = "收起"
                } else {
                    tvContent.maxLines = 3
                    btnExpand.text = "展开更多内容"
                }
            }

            // 复制单个结果
            btnCopyItem.setOnClickListener {
                copyToClipboard(itemView.context, item.content, "[${item.index}]")
            }

            // 点击卡片也复制
            cardItem.setOnClickListener {
                copyToClipboard(itemView.context, item.content, "[${item.index}]")
            }
        }

        private fun copyToClipboard(context: Context, text: String, label: String) {
            val clipboard = context.getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
            val clip = ClipData.newPlainText("Crawler Result", text)
            clipboard.setPrimaryClip(clip)
            Toast.makeText(context, "已复制: $label", Toast.LENGTH_SHORT).show()
        }

        /**
         * 估算文本行数（按每行约 40 个字符估算）
         */
        private fun estimateLineCount(text: String): Int {
            if (text.isEmpty()) return 0
            val lines = text.split("\n")
            var totalLines = 0
            for (line in lines) {
                if (line.isEmpty()) {
                    totalLines += 1
                } else {
                    totalLines += (line.length / 40) + 1
                }
            }
            return totalLines
        }

        /**
         * 从内容中提取属性标签，返回形如 "@title @href @data-src text()" 的字符串
         */
        private fun extractAttrTags(content: String): String {
            val tags = mutableSetOf<String>()

            // 匹配 @xxx 属性
            val attrPattern = Pattern.compile("@(\\w[\\w-]*)")
            val attrMatcher = attrPattern.matcher(content)
            while (attrMatcher.find()) {
                tags.add("@${attrMatcher.group(1)}")
            }

            // 检查是否包含 text()
            if (content.contains("text()", ignoreCase = true) ||
                content.contains("text=\"", ignoreCase = true)
            ) {
                tags.add("text()")
            }

            // 如果没有找到任何标签，尝试从原始内容中提取关键词
            if (tags.isEmpty()) {
                // 从内容片段中推断可能的属性
                val commonAttrs = listOf("title", "href", "src", "data-src", "data-original", "alt", "class", "id")
                for (attr in commonAttrs) {
                    if (content.contains(attr, ignoreCase = true)) {
                        tags.add("@$attr")
                        if (tags.size >= 6) break
                    }
                }
            }

            return if (tags.isEmpty()) {
                ""
            } else {
                tags.take(6).joinToString("  ")
            }
        }

        /**
         * 将 HTML 代码片段转换为带语法高亮的 SpannableString
         * 标签名 → 蓝色（html_tag_color）
         * 属性名 → 红色（html_attr_color）
         * 属性值 → 绿色（html_value_color）
         */
        private fun highlightHtmlContent(context: Context, rawContent: String): CharSequence {
            val sb = SpannableStringBuilder()

            // 先进行 HTML 转义，防止文本中的 < > & 被解析
            val escaped = rawContent
                .replace("&", "&")
                .replace("<", "<")
                .replace(">", ">")

            val tagColor = ContextCompat.getColor(context, R.color.html_tag_color)
            val attrColor = ContextCompat.getColor(context, R.color.html_attr_color)
            val valueColor = ContextCompat.getColor(context, R.color.html_value_color)
            val textColor = ContextCompat.getColor(context, R.color.html_text_color)

            // 分词解析，识别标签、属性、属性值、纯文本
            val tokenPattern = Pattern.compile(
                "(<[^&]*>)" +        // 完整的标签，如 <div class="main">
                "|(@\\w[\\w-]*)" +         // @属性标记，如 @title
                "|(\\w+)(?==\"[^\"]*\")" + // 属性名后面的 ="...", 用前瞻捕获属性名
                "|(\"[^\"]*\")"            // 双引号字符串（属性值）
            )
            val matcher = tokenPattern.matcher(escaped)
            var lastEnd = 0

            while (matcher.find()) {
                // 添加匹配前的纯文本
                if (matcher.start() > lastEnd) {
                    sb.append(escaped.substring(lastEnd, matcher.start()))
                }

                val fullTag = matcher.group(1)  // 完整的 <...>
                val attrMark = matcher.group(2) // @title 形式
                val attrName = matcher.group(3) // 属性名（等号前的部分）
                val quotedStr = matcher.group(4) // "..."
                val matchedText = matcher.group()

                when {
                    fullTag != null -> {
                        // 对整个标签上色（默认颜色），然后内部再细拆
                        val innerSb = SpannableStringBuilder()
                        val innerPattern = Pattern.compile(
                            "(</?)" +          // 开始标签或结束标签的 < 部分
                            "|(/>)" +           // 自闭合标签的 /> 部分
                            "|(>)" +            // 单纯 > 
                            "|(/?[a-zA-Z][\\w-]*)" // 标签名或结束标签的斜杠+标签名
                        )
                        val innerMatcher = innerPattern.matcher(fullTag)
                        var innerLast = 0
                        while (innerMatcher.find()) {
                            if (innerMatcher.start() > innerLast) {
                                innerSb.append(fullTag.substring(innerLast, innerMatcher.start()))
                            }
                            val bracket1 = innerMatcher.group(1) // < 或 </
                            val selfClose = innerMatcher.group(2) // />
                            val bracket2 = innerMatcher.group(3) // >
                            val tagName = innerMatcher.group(4)  // 标签名
                            when {
                                bracket1 != null -> {
                                    val s = SpannableStringBuilder(bracket1)
                                    s.setSpan(ForegroundColorSpan(textColor), 0, s.length, 0)
                                    innerSb.append(s)
                                }
                                selfClose != null -> {
                                    val s = SpannableStringBuilder(selfClose)
                                    s.setSpan(ForegroundColorSpan(textColor), 0, s.length, 0)
                                    innerSb.append(s)
                                }
                                bracket2 != null -> {
                                    val s = SpannableStringBuilder(bracket2)
                                    s.setSpan(ForegroundColorSpan(textColor), 0, s.length, 0)
                                    innerSb.append(s)
                                }
                                tagName != null -> {
                                    val s = SpannableStringBuilder(tagName)
                                    s.setSpan(ForegroundColorSpan(tagColor), 0, s.length, 0)
                                    innerSb.append(s)
                                }
                            }
                            innerLast = innerMatcher.end()
                        }
                        if (innerLast < fullTag.length) {
                            innerSb.append(fullTag.substring(innerLast))
                        }
                        sb.append(innerSb)
                    }
                    attrMark != null -> {
                        // @属性标记，红色
                        val s = SpannableStringBuilder(attrMark)
                        s.setSpan(ForegroundColorSpan(attrColor), 0, s.length, 0)
                        sb.append(s)
                    }
                    attrName != null && quotedStr != null -> {
                        // 属性名红色，属性值绿色
                        val attrStr = attrName + "="
                        val s = SpannableStringBuilder(attrStr)
                        s.setSpan(ForegroundColorSpan(attrColor), 0, s.length, 0)
                        sb.append(s)

                        val valStr = quotedStr
                        val s2 = SpannableStringBuilder(valStr)
                        s2.setSpan(ForegroundColorSpan(valueColor), 0, s2.length, 0)
                        sb.append(s2)
                    }
                    quotedStr != null -> {
                        // 单独引号字符串
                        val s = SpannableStringBuilder(quotedStr)
                        s.setSpan(ForegroundColorSpan(valueColor), 0, s.length, 0)
                        sb.append(s)
                    }
                    else -> {
                        sb.append(matchedText)
                    }
                }

                lastEnd = matcher.end()
            }

            // 追加剩余文本
            if (lastEnd < escaped.length) {
                sb.append(escaped.substring(lastEnd))
            }

            return sb
        }
    }

    class DiffCallback : DiffUtil.ItemCallback<ResultItem>() {
        override fun areItemsTheSame(oldItem: ResultItem, newItem: ResultItem): Boolean {
            return oldItem.index == newItem.index
        }

        override fun areContentsTheSame(oldItem: ResultItem, newItem: ResultItem): Boolean {
            return oldItem == newItem
        }
    }
}